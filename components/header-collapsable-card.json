  "usage": {
    "do": [
      "Use only as the header slot inside SS-collapsable-card",
      "Always pair with a divider when the card body is expanded",
      "Use the dropdown toggle to signal that the card body can be shown or hidden"
    ],
    "dont": [
      "Don't use this header standalone outside of a collapsable card",
      "Don't remove the chevron icon — it is the primary affordance for expand/collapse"
    ]
  },
  "accessibility": {

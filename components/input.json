{
  "name": "Input Field",
  "description": "Single-line form field for short text or numeric entry in admin forms.",
  "category": "Forms",
  "variants": {
    "type": [
      "default",
      "button-trailing",
      "leading-text",
      "trailing-text"
    ],
    "destructive": [
      false,
      true
    ],
    "line": [
      "1",
      "3"
    ]
  },
  "states": [
    "enabled",
    "hover",
    "focused",
    "filled",
    "disabled"
  ],
  "props": {
    "type": {
      "type": "enum",
      "default": "default",
      "options": [
        "default",
        "button-trailing",
        "leading-text",
        "trailing-text"
      ],
      "description": "Controls the input field variant — plain, with a trailing button, or with leading/trailing text."
    },
    "destructive": {
      "type": "boolean",
      "default": false,
      "description": "Shows validation error styling. Pair with error hint text."
    },
    "line": {
      "type": "enum",
      "default": "1",
      "options": [
        "1",
        "3"
      ],
      "description": "Number of visible lines. Use 3 for multi-line (textarea) mode."
    },
    "label": {
      "type": "boolean",
      "default": true,
      "description": "Shows the field label above the input."
    },
    "hintText": {
      "type": "boolean",
      "default": true,
      "description": "Shows helper or error text below the input."
    },
    "characterLimit": {
      "type": "boolean",
      "default": true,
      "description": "Shows a character count indicator."
    },
    "showHintTextAndCharacterLimit": {
      "type": "boolean",
      "default": true,
      "description": "Controls visibility of the hint + character limit row."
    },
    "mandatory": {
      "type": "boolean",
      "default": true,
      "description": "Shows a required field indicator next to the label."
    },
    "infoIcon": {
      "type": "boolean",
      "default": true,
      "description": "Shows an info icon next to the label."
    },
    "labelInfo": {
      "type": "boolean",
      "default": true,
      "description": "Shows additional label info text."
    },
    "hint": {
      "type": "boolean",
      "default": true,
      "description": "Shows hint text inside or near the input."
    },
    "leadingText": {
      "type": "boolean",
      "default": true,
      "description": "Shows prefix text inside the input (e.g. currency symbol)."
    },
    "trailingText": {
      "type": "boolean",
      "default": true,
      "description": "Shows suffix text inside the input (e.g. unit)."
    }
  },
  "tokens": {
    "surface": {
      "enabled": "input/bg",
      "hover": "input/bg-hover",
      "disabled": "input/bg-disabled"
    },
    "text": {
      "value": "input/fg",
      "placeholder": "input/fg-placeholder",
      "disabled": "input/fg-disabled",
      "label": "input/label",
      "mandatory": "input/mandatory",
      "hint": "input/hint-message",
      "error": "input/error-message"
    },
    "icon": {
      "info": "input/icon-info"
    },
    "border": {
      "enabled": "input/border",
      "focus": "input/border-focus",
      "error": "input/border-error"
    }
  },
  "spacing": {
    "width": "320px",
    "height": "62px",
    "padding-x": "app-spacing/s8",
    "padding-y": "app-spacing/s6",
    "gap": "app-spacing/s2",
    "border-radius": "radius/medium",
    "border-width": "stroke/s1",
    "icon-size": "icon-size/xs",
    "icon-size-info": "icon-size/xxs"
  },
  "typography": {
    "font-family": "typography/font/family",
    "label": {
      "font-size": "typography/font-size/xs",
      "font-weight": "typography/font-weight/semibold(600)"
    },
    "value": {
      "font-size": "typography/font-size/xs",
      "font-weight": "typography/font-weight/regular(400)"
    }
  },
  "usage": {
    "do": [
      "Use for one-line entries such as names, labels, IDs, counts, or prices",
      "Use line=3 for short multi-line content",
      "Use destructive state only when validation has failed",
      "Pair destructive with clear error hint text"
    ],
    "dont": [
      "Don't use for long-form content — use a text area component instead",
      "Don't combine disabled and destructive states",
      "Don't rely on placeholder text as a substitute for a visible label"
    ]
  },
  "accessibility": {
    "role": "textbox",
    "aria": [
      "aria-label",
      "aria-required (when mandatory)",
      "aria-invalid (when destructive)",
      "aria-describedby (hint text)"
    ],
    "keyboard": "Tab to focus, type to enter value. Label should remain visible at all times. Focus styling must clearly indicate keyboard focus."
  },
  "examples": [
    {
      "label": "Default enabled",
      "props": {
        "type": "default",
        "destructive": false
      }
    },
    {
      "label": "Default with error",
      "props": {
        "type": "default",
        "destructive": true
      }
    },
    {
      "label": "Disabled",
      "props": {
        "type": "default",
        "disabled": true
      }
    },
    {
      "label": "With trailing button",
      "props": {
        "type": "button-trailing"
      }
    },
    {
      "label": "With leading text",
      "props": {
        "type": "leading-text"
      }
    },
    {
      "label": "With trailing text",
      "props": {
        "type": "trailing-text"
      }
    },
    {
      "label": "Multi-line (3 lines)",
      "props": {
        "type": "default",
        "line": "3"
      }
    }
  ]
}

  "props": {
    "type": {
      "type": "enum",
      "default": "Default",
      "options": ["Default", "Button Trailing", "Leading Text", "Trailing Text"],
      "description": "Input variant. Default is plain; Button Trailing adds an action button; Leading/Trailing Text adds a prefix or suffix label."
    },
    "destructive": {
      "type": "boolean",
      "default": false,
      "description": "Shows validation error styling. Pair with error hint text. Do not combine with disabled."
    },
    "state": {
      "type": "enum",
      "default": "Enabled",
      "options": ["Enabled", "Hover", "Focused", "Filled", "Disabled"],
      "description": "Interactive state of the input field."
    },
    "line": {
      "type": "enum",
      "default": "1",
      "options": ["1", "3"],
      "description": "Number of visible lines. Use 3 for multi-line (textarea) mode. Only available with Default and Button Trailing types."
    },
    "label": {
      "type": "boolean",
      "default": true,
      "description": "Shows the field label above the input."
    },
    "mandatory": {
      "type": "boolean",
      "default": true,
      "description": "Shows a required field indicator (*) next to the label."
    },
    "infoIcon": {
      "type": "boolean",
      "default": true,
      "description": "Shows an info icon next to the label."
    },
    "hintText": {
      "type": "boolean",
      "default": true,
      "description": "Shows helper or error text below the input."
    },
    "characterLimit": {
      "type": "boolean",
      "default": true,
      "description": "Shows a character count indicator (e.g. 12/500)."
    },
    "showHintTextAndCharacterLimit": {
      "type": "boolean",
      "default": true,
      "description": "Controls visibility of the entire hint + character limit row below the input."
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Prevents interaction. Maps to State=Disabled in Figma. Do not combine with destructive."
    }
  },

  "constraints": [
    "Primary type always renders with a border (outlined). Secondary type is ghost — no border except when focused.",
    "Both types share the button/secondary token set. Primary adds a persistent border; Secondary adds it only on focus.",
    "Icon fg tokens are shared across both types in equivalent states."
  ],

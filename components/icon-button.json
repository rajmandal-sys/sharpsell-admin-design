  "usage": {
    "do": [
      "Use for compact toolbar-style actions where the icon meaning is clear",
      "Always provide an aria-label since there is no visible text",
      "Use Primary (outlined) when a persistent border helps distinguish it from surrounding content",
      "Use Secondary (ghost) for subtle inline actions in dense layouts"
    ],
    "dont": [
      "Don't use if the action meaning is ambiguous without a label",
      "Don't use as a primary call to action — use Button instead",
      "Don't omit aria-label — without it the button is inaccessible to screen readers"
    ]
  },
  "accessibility": {
    "role": "button",
    "aria": [
      "aria-label (required — no visible text)",
      "aria-disabled"
    ],
    "keyboard": "Tab to focus, Enter or Space to activate. Focused state must remain clearly visible."

{
  "name": "Dropdown Single Select",
  "description": "Single-select dropdown for choosing one value from a predefined list.",
  "category": "Forms",
  "variants": {
    "destructive": [
      false,
      true
    ]
  },
  "states": [
    "enabled",
    "hover",
    "focused",
    "open",
    "filled",
    "disabled"
  ],
  "props": {
    "destructive": {
      "type": "boolean",
      "default": false,
      "description": "Error styling when selection is required or the chosen value is invalid."
    },
    "label": {
      "type": "boolean",
      "default": true,
      "description": "Shows the field label above the dropdown."
    },
    "hintText": {
      "type": "boolean",
      "default": true,
      "description": "Shows helper or error text below the dropdown."
    },
    "scrollBar": {
      "type": "boolean",
      "default": true,
      "description": "Shows a scrollbar in the dropdown menu when options overflow."
    },
    "mandatory": {
      "type": "boolean",
      "default": true,
      "description": "Shows a required field indicator next to the label."
    },
    "labelInfo": {
      "type": "boolean",
      "default": true,
      "description": "Shows additional info text next to the label."
    }
  },
  "tokens": {
    "field": {
      "surface": {
        "enabled": "input-dropdown/bg",
        "hover": "input-dropdown/bg-hover",
        "disabled": "input-dropdown/bg-disabled"
      },
      "text": {
        "value": "input-dropdown/fg",
        "placeholder": "input-dropdown/fg-placeholder",
        "disabled": "input-dropdown/fg-disabled",
        "label": "input-dropdown/label",
        "mandatory": "input-dropdown/mandatory",
        "hint": "input-dropdown/hint-message",
        "error": "input-dropdown/error-message"
      },
      "icon": {
        "arrow": "input-dropdown/icon-arrow",
        "info": "input-dropdown/icon-info"
      },
      "border": {
        "enabled": "input-dropdown/border",
        "focus": "input-dropdown/border-focus",
        "error": "input-dropdown/border-error"
      }
    },
    "menu": {
      "surface": "input-dropdown/menu-bg",
      "border": "input-dropdown/menu-border",
      "scrollbar": "input-dropdown/menu-scrollbar",
      "item": {
        "text": "input-dropdown/menu-item-fg",
        "surface-selected": "input-dropdown/menu-item-bg-selected",
        "icon-check": "input-dropdown/menu-item-icon-check"
      }
    },
    "search": {
      "surface": "input-search/bg",
      "border": "input-search/border",
      "text": "input-search/fg",
      "hint": "input-search/hint-message",
      "icon-info": "input-search/icon-info",
      "icon-search": "input-search/icon-search"
    }
  },
  "spacing": {
    "width": "320px",
    "height": "62px",
    "gap": "app-spacing/s2",
    "border-radius": "radius/medium",
    "menu-border-radius": "radius/small",
    "border-width": "stroke/s1",
    "icon-size": "icon-size/xs",
    "icon-size-info": "icon-size/xxs"
  },
  "typography": {
    "font-family": "typography/font/family",
    "label": {
      "font-size": "typography/font-size/xs",
      "font-weight": "typography/font-weight/semibold(600)"
    },
    "value": {
      "font-size": "typography/font-size/xs",
      "font-weight": "typography/font-weight/regular(400)"
    },
    "menu-item": {
      "font-size": "typography/font-size/sm",
      "font-weight": "typography/font-weight/regular(400)"
    }
  },
  "usage": {
    "do": [
      "Use when users must select exactly one option from a controlled set",
      "Use for status, role, country, category, or other finite lists",
      "Use Open only as an interactive state while the menu is visible"
    ],
    "dont": [
      "Don't use for multi-select behavior — use Multi Select instead",
      "Don't use when free-form text entry is allowed — use Input instead"
    ]
  },
  "accessibility": {
    "role": "listbox",
    "aria": [
      "aria-expanded",
      "aria-haspopup",
      "aria-required (when mandatory)",
      "aria-invalid (when destructive)"
    ],
    "keyboard": "Arrow keys move through options, Enter selects, Escape closes the list."
  },
  "examples": [
    {
      "label": "Default enabled",
      "props": {
        "destructive": false
      }
    },
    {
      "label": "Open with options",
      "props": {
        "state": "open"
      }
    },
    {
      "label": "Filled",
      "props": {
        "state": "filled"
      }
    },
    {
      "label": "With error",
      "props": {
        "destructive": true
      }
    },
    {
      "label": "Disabled",
      "props": {
        "disabled": true
      }
    }
  ]
}
